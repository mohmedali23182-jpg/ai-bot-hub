# App Configuration
APP_NAME="AI Bot Hub"
APP_ENV="production"
PORT=8000
BASE_URL="https://your-app.up.railway.app"
LOG_LEVEL="INFO"

# Telegram Configuration
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_WEBHOOK_SECRET="a_very_long_random_string"
TELEGRAM_ADMIN_IDS="12345678,87654321"
DASHBOARD_PASSWORD="change_this_password"

# AI Provider Configuration
# Options: gemini | openai_compatible | openrouter
AI_PROVIDER="gemini"
AI_API_KEY="your_api_key_here"

# Model Selection (Default to Gemini 2.0 Flash)
AI_MODEL_TEXT="gemini-2.0-flash"
AI_MODEL_VISION="gemini-2.0-flash"
AI_MODEL_AUDIO="gemini-2.0-flash"
AI_MODEL_VIDEO="gemini-2.0-flash"
AI_MODEL_CODE="gemini-2.0-flash"

# OpenAI Compatible Settings
OPENAI_COMPAT_BASE_URL="https://api.openai.com/v1"
OPENAI_COMPAT_VISION_INPUT_MODE="url" # url | base64

# OpenRouter Settings
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_HTTP_REFERER="https://github.com/mohmedali23182-jpg/ai-bot-hub"
OPENROUTER_APP_NAME="AI Bot Hub"

# Operational Limits
MAX_HISTORY_TURNS=10
ENABLE_TYPING=True
REQUEST_TIMEOUT=90.0
GEMINI_MAX_INLINE_BYTES=18874368 # 18MB
DB_PATH="data/bot.db"
MAX_TELEGRAM_MESSAGE_LEN=4096
DOWNLOAD_RETRIES=3
API_RETRIES=3
