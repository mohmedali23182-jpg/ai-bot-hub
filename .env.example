APP_NAME=AI Bot Hub
APP_ENV=production
PORT=8000
BASE_URL=https://your-real-app.up.railway.app
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-long-secret
TELEGRAM_ADMIN_IDS=8185788415
DASHBOARD_PASSWORD=change-me-password

AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL_TEXT=gemini-2.5-flash
AI_MODEL_VISION=gemini-2.5-flash
AI_MODEL_AUDIO=gemini-2.5-flash
AI_MODEL_VIDEO=gemini-2.5-flash
AI_MODEL_CODE=gemini-2.5-flash
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_VISION_INPUT_MODE=url

GEMINI_MAX_INLINE_BYTES=18874368
REQUEST_TIMEOUT=90
MAX_HISTORY_TURNS=8
ENABLE_TYPING=true
DB_PATH=bot.db
MAX_TELEGRAM_MESSAGE_LEN=4096
DOWNLOAD_RETRIES=3
API_RETRIES=2
